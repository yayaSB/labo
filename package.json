{
  "name": "labresa",
  "private": true,
  "workspaces": [
    "frontend"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "python manage.py runserver",
    "dev:frontend": "npm --workspace frontend run dev",
    "build": "npm --workspace frontend run build"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
